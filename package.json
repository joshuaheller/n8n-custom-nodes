  "description": "n8n custom node to validate EU VAT numbers via the official VIES SOAP API",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "vat",
    "vies",
    "eu",
    "validator"
  ],
  "license": "MIT",
  "homepage": "https://github.com/your-username/n8n-nodes-vat-validator",
