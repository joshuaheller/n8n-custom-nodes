    "name": "Your Name"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/n8n-nodes-vat-validator.git"
  },
  "main": "index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch"
  },
